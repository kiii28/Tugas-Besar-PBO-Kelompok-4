<?xml version="1.0" encoding="UTF-8"?>
<Context>

    <!--
        context.xml
        Lokasi file: Web Pages/META-INF/context.xml

        File ini memberitahu server (GlassFish/Tomcat) cara
        konek ke database MySQL untuk proyek EcoRide.

        PENTING: sesuaikan username dan password MySQL kalian
        di bawah sebelum menjalankan aplikasi.
    -->

    <Resource
        name="jdbc/ecoride"
        auth="Container"
        type="javax.sql.DataSource"
        maxActive="10"
        maxIdle="5"
        maxWait="10000"
        driverClassName="com.mysql.cj.jdbc.Driver"
        url="jdbc:mysql://localhost:3306/ecoride_db?useSSL=false&amp;serverTimezone=Asia/Jakarta&amp;allowPublicKeyRetrieval=true"
        username="root"
        password=""
    />

    <!--
        Penjelasan atribut:
        - name        : nama referensi, dipanggil di DBConnection.java
        - maxActive   : maksimal 10 koneksi sekaligus
        - maxIdle     : 5 koneksi standby saat tidak dipakai
        - maxWait     : tunggu max 10 detik sebelum error
        - url         : ganti "root" dan password sesuai MySQL kalian
        - username    : username MySQL (default: root)
        - password    : password MySQL (kosongkan jika tidak ada password)
    -->

</Context>